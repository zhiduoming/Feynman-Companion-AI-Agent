# Copy this file to .env.local and fill your own DeepSeek API key.
# Never commit .env.local.

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
LLM_PROVIDER=deepseek

# Mock 开关：false=走真实数据库，true=返回假数据
MATERIAL_MOCK=false

# Optional: increase this if DeepSeek responses are slow.
REQUEST_TIMEOUT_SECONDS=30

# Authentication. Generate a local value with: openssl rand -hex 32
AUTH_SECRET_KEY=replace_with_a_long_random_secret
AUTH_TOKEN_EXPIRE_MINUTES=1440
